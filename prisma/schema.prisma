generator client {
  provider = "prisma-client"
  output   = "../backend/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLATFORM_ADMIN
  ESTABLISHMENT_ADMIN
}

enum EstablishmentStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum PricingType {
  UNIT
  HUNDRED
  KG
}

model User {
  id           String              @id @default(uuid()) @db.Uuid
  name         String
  email        String              @unique
  passwordHash String
  role         UserRole            @default(ESTABLISHMENT_ADMIN)
  memberships  EstablishmentUser[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("users")
}

model Establishment {
  id            String              @id @default(uuid()) @db.Uuid
  name          String
  slug          String              @unique
  subdomain     String              @unique
  status        EstablishmentStatus @default(ACTIVE)
  whatsappPhone String
  address       String?
  logoUrl       String?
  bannerUrl     String?
  primaryColor  String              @default("#f97316")
  deliveryFee   Decimal             @default(0) @db.Decimal(10, 2)
  minimumOrder  Decimal             @default(0) @db.Decimal(10, 2)
  openingHours  Json?
  users         EstablishmentUser[]
  categories    Category[]
  products      Product[]
  orders        Order[]
  visits        MenuVisit[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("establishments")
}

model EstablishmentUser {
  userId          String        @db.Uuid
  establishmentId String        @db.Uuid
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@id([userId, establishmentId])
  @@map("establishment_users")
}

model Category {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  displayOrder    Int           @default(0)
  isActive        Boolean       @default(true)
  products        Product[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([establishmentId, slug])
  @@index([establishmentId, displayOrder])
  @@map("categories")
}

model Product {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  categoryId      String        @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name            String
  slug            String
  description     String?
  price           Decimal       @db.Decimal(10, 2)
  pricingType     PricingType   @default(UNIT)
  minQuantity     Decimal?      @db.Decimal(10, 3)
  stepQuantity    Decimal       @default(1) @db.Decimal(10, 3)
  imageUrl        String?
  isActive        Boolean       @default(true)
  displayOrder    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([establishmentId, slug])
  @@index([establishmentId, categoryId])
  @@index([establishmentId, displayOrder])
  @@map("products")
}

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  customerName    String?
  customerPhone   String?
  items           Json
  totalAmount     Decimal       @db.Decimal(10, 2)
  whatsappUrl     String?
  createdAt       DateTime      @default(now())

  @@index([establishmentId, createdAt])
  @@map("orders")
}

model MenuVisit {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  source          String?
  userAgent       String?
  createdAt       DateTime      @default(now())

  @@index([establishmentId, createdAt])
  @@map("menu_visits")
}
