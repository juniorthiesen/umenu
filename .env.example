# Postgres
POSTGRES_DB=umenu
POSTGRES_USER=umenu
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://umenu:change-me@localhost:5432/umenu

# API
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3333
APP_DOMAIN=localhost
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
JWT_SECRET=change-this-development-secret-with-32-chars
UPLOAD_DIR=uploads

# Primeiro admin da plataforma, usado por npm run seed:admin
ADMIN_NAME=Admin UMenu
ADMIN_EMAIL=admin@umenu.local
ADMIN_PASSWORD=change-me-admin-password

# Frontend
VITE_API_URL=http://localhost:3333
